<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>MilkMate</title>
  <link rel="stylesheet" href="../css/user/front.css"/>
</head>
<body>

  <!-- Navbar -->
  <header class="navbar">
    <div class="logo">
        <img src="https://static.vecteezy.com/system/resources/previews/048/342/900/non_2x/cartoon-cow-logo-png.png" alt="MilkMate Logo">
    </div>
    <h1 class="title">MILKMATE</h1>
    <nav class="nav-links">
      <% if (!currUser) { %>
        <a href="/signup">New User</a>
        <a href="/login">Login</a>
      <% } %>
      <%if(currUser) { %> 
      <a href="/logout">Logout</a>
      <%}%>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
    </nav>
</header>

  <!-- Hero Section -->
  <section class="hero">
    <div class="container hero-content-wrapper">
      <div class="hero-image">
        <img src="https://th.bing.com/th/id/OIP.j8AHGOtscDn3VzhTLVdJmAHaE8?pid=ImgDet&w=202&h=134&c=7&dpr=1.3" alt="Milk being poured"/>
      </div>
      <div class="hero-content">
        <div>
        <h1>Get Started Now</h1>
        <p>Effortless Milk Management with MilkMate</p> 
      </div></div>
  </section>
  <p class="option"><b></b></p>
  <div class="btn-option">
    <% if(currUser && currUser.type=="dairy") {%>
      <div class="return-btn-wrapper">
        <p><b>Return to:</b> 
          <a href="/dairy">
            <button class="btn btn-secondary">Dairy</button>
          </a>
        </p>
      </div>   
<%}%>

    <% if(currUser && currUser.type=="milkman") {%>
      <div class="return-btn-wrapper">
        <p><b>Return to:</b> 
          <a href="/milkman">
            <button class="btn btn-secondary">Milkman Page</button>
          </a>
        </p>
      </div>  <%}%>

    <% if(currUser && currUser.type=="customer") {%>
      <div class="return-btn-wrapper">
        <p><b>Return to:</b> 
          <a href="/customer">
            <button class="btn btn-secondary">Customer Page</button>
          </a>
        </p>
      </div>  <a href="/customerrs"><button class="btn btn-secondary">Customer</button></a>
    <%}%>

  </div>

  <!-- Illustration Section -->
  <section class="illustration container">
    <img src="https://th.bing.com/th/id/OIP.RIUOMY7h4cYAiin0sc2iSgHaHa?pid=ImgDet&w=202&h=202&c=7&dpr=1.3" alt="Milkify app and farmer illustration"/>
    <p><strong>Milk Management, Simplified by MilkMate.</strong></p>
  </section>

  <!-- Footer -->
  <footer class="site-footer" style="width: 100%;">
    <div class="footer-content">
        <div class="footer-section">
            <h3>MILKMATE</h3>
            <p>Your smart partner in dairy management. Trusted by farms and cooperatives for reliable operations and milk traceability.</p>
        </div>

        <div class="footer-section">
            <h4>Quick Links</h4>
            <ul>
                <li><a href="/">Home</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/contact">Contact</a></li>
            </ul>
        </div>

        <div class="footer-section">
            <h4>Contact Us</h4>
            <p>Email: info@milkmate.com</p>
            <p>Phone: +91 79739 18569</p>
            <p>Location: Indore, Madhya Pradesh, India</p>
        </div>
    </div>

    <div class="footer-bottom">
        <p>&copy; 2025 MILKMATE. All rights reserved.</p>
    </div>
</footer>

</body>
</html>
