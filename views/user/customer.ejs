<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Customer Registration</title>
  <link rel="stylesheet" href="../css/user/customer.css"/>
</head>
<body>

  <% if (success && success.length > 0) { %>
    <div class="alert alert-success"><%= success[0] %></div>
  <% } else if (error && error.length > 0) { %>
    <div class="alert alert-danger"><%= error[0] %></div>
  <% } %>

  <div class="container">
    <div class="form-container">
      <h2>Customer Registration</h2>
      <form action="/signup/customer" method="POST" id="customerForm">

        <b>Customer Code</b>
        <input type="number" name="customerr[code]" placeholder="Customer Code" required>
        <div class="input-alert" id="code-alert"></div>

        <b>Dairy Code</b>
        <input type="number" name="customerr[codeD]" placeholder="Dairy Code" required>
        <div class="input-alert" id="codeD-alert"></div>

        <b>Contact Number</b>
        <input type="tel" name="customerr[contact]" placeholder="Contact Number" required pattern="[0-9]{10}">
        <div class="input-alert" id="contact-alert"></div>

        <b>Password</b>
        <input type="password" name="customerr[password]" placeholder="Password" required>
        <div class="input-alert" id="password-alert"></div>

        <b>Confirm Password</b>
        <input type="password" name="customerr[confirmPassword]" placeholder="Confirm Password" required>
        <div class="input-alert" id="confirmPassword-alert"></div>

        <button type="submit" class="btn-1">Register</button>
      </form>

      <a href="/login"><button type="button" class="btn-2">Already Registered? Login</button></a>
      <a href="/signup"><button type="button" class="btn-2">Back</button></a>
    </div>
  </div>

  <script>
    // Hide alert after 4 seconds
    setTimeout(() => {
      const alert = document.querySelector(".alert");
      if (alert) alert.style.display = "none";
    }, 4000);
  </script>

  <style>
    .input-alert {
      color: red;
      font-size: 0.85em;
      margin-top: -10px;
      margin-bottom: 10px;
    }
    .alert {
      text-align: center;
      padding: 10px;
      margin: 15px;
      border-radius: 4px;
    }
    .alert-success {
      background-color: #d4edda;
      color: #155724;
    }
    .alert-danger {
      background-color: #f8d7da;
      color: #721c24;
    }
  </style>

</body>
</html>
