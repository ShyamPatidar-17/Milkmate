<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Customer Registration</title>
    <link rel="stylesheet" href="../css/user/customer.css">
</head>
<body>
<div class="container">
    <div class="form-container">
        <h2>Customer Registration</h2>
        <form action="/signup/customer" method="post">
            <input type="text" name="customerr[code]" placeholder="Customer Code" required>
            <input type="text" name="customerr[codeD]" placeholder="Dairy Code" required>
            <input type="tel" name="customerr[contact]" placeholder="Contact Number" required>
            <input type="password" name="customerr[password]" placeholder="Password" required>
            <input type="password" name="customerr[confirmPassword]" placeholder="Confirm Password" required>
            <button type="submit" class="btn-1">Register</button>
        </form>

        <a href="/login"><button type="submit" class="btn-2">Already Registerd? Login</button></a>
        <a href="/signup"><button type="submit" class="btn-2">Back</button></a>
    </div>

</div>
</body>
</html>
