<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Milkman Registration</title>
  <link rel="stylesheet" href="../css/user/milkman.css" />
  <style>
    .input-error {
      color: red;
      font-size: 0.9em;
      margin-bottom: 8px;
      display: none;
    }
    input.invalid {
      border: 2px solid red;
    }
  </style>
</head>
<body>
  <div class="background-overlay">
    <div class="form-container">
      <h2>Milkman Registration</h2>
      <form id="milkmanForm" action="/signup/milkman" method="post" novalidate>
        
        <input type="number" name="milkman[milkmanCode]" placeholder="Milkman Code" required>
        <div class="input-error" id="codeError">Please enter a valid code.</div>

        <input type="text" name="milkman[name]" placeholder="Full Name" required>
        <div class="input-error" id="nameError">Please enter your full name.</div>

        <input type="email" name="milkman[email]" placeholder="Email" required>
        <div class="input-error" id="emailError">Enter a valid email address.</div>

        <input type="number" name="milkman[contact]" placeholder="Contact Number" required>
        <div class="input-error" id="contactError">Enter a 10-digit contact number.</div>

        <input type="text" name="milkman[address]" placeholder="Address" required>
        <div class="input-error" id="addressError">Enter your address.</div>

        <input type="password" name="milkman[password]" placeholder="Password" required>
        <div class="input-error" id="passwordError">Password must be at least 6 characters.</div>

        <input type="password" name="milkman[confirmPassword]" placeholder="Confirm Password" required>
        <div class="input-error" id="confirmError">Passwords do not match.</div>

        <button class="btn-1" type="submit">Register</button>
      </form>

      <div class="form-links">
        <a href="/login"><button class="btn-2">Already Registered? Login</button></a>
        <a href="/signup"><button class="btn-2">Back</button></a>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('milkmanForm');

    form.addEventListener('submit', function (e) {
      let valid = true;

      const fields = {
        milkmanCode: form.querySelector('input[name="milkman[milkmanCode]"]'),
        name: form.querySelector('input[name="milkman[name]"]'),
        email: form.querySelector('input[name="milkman[email]"]'),
        contact: form.querySelector('input[name="milkman[contact]"]'),
        address: form.querySelector('input[name="milkman[address]"]'),
        password: form.querySelector('input[name="milkman[password]"]'),
        confirmPassword: form.querySelector('input[name="milkman[confirmPassword]"]')
      };

      const showError = (field, errorId, condition) => {
        const error = document.getElementById(errorId);
        if (condition) {
          error.style.display = 'block';
          field.classList.add('invalid');
          valid = false;
        } else {
          error.style.display = 'none';
          field.classList.remove('invalid');
        }
      };

      showError(fields.milkmanCode, 'codeError', !fields.milkmanCode.value.trim());
      showError(fields.name, 'nameError', !fields.name.value.trim());
      showError(fields.email, 'emailError', !/^\S+@\S+\.\S+$/.test(fields.email.value));
      showError(fields.contact, 'contactError', !/^\d{10}$/.test(fields.contact.value));
      showError(fields.address, 'addressError', !fields.address.value.trim());
      showError(fields.password, 'passwordError', fields.password.value.length < 6);
      showError(fields.confirmPassword, 'confirmError', fields.confirmPassword.value !== fields.password.value);

      if (!valid) e.preventDefault();
    });
  </script>
</body>
</html>
