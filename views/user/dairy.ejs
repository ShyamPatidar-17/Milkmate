<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up - Dairy Management</title>
    <link rel="stylesheet" href="../css/user/dairy.css">
</head>
<body>

    <div class="form-container">
        <h2>Sign Up as Dairy Owner</h2>
        <form action="/signup/dairy" method="POST">
            <input type="text" name="dairy[dairyCode]" placeholder="Dairy Code" required>
            <input type="text" name="dairy[fullName]" placeholder="Owner Name" required>
            <input type="text" name="dairy[dairyName]" placeholder="Dairy Name" required>
            <input type="text" name="dairy[dairyAddress]" placeholder="Dairy Address" required>
            <input type="email" name="dairy[email]" placeholder="Email Address" required>
            <input type="tel" name="dairy[contact]" placeholder="Contact Number" required>
            <input type="password" name="dairy[password]" placeholder="Password" required>
            <input type="password" name="dairy[confirmPassword]" placeholder="Confirm Password" required>
            <button class="btn-1" type="submit">Register</button>
        </form>
        <a href="/login"><button type="submit" class="btn-2">Already Registerd? Login</button></a>
        <a href="/signup"><button type="submit" class="btn-2">Back</button></a>
    </div>

</body>
</html>
