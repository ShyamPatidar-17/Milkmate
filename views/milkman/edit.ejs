<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>EDIT CUSTOMER</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap');

    body {
      font-family: 'Poppins', sans-serif;
      background: linear-gradient(to right, #141e30, #243b55);
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      margin: 0;
    }

    .container {
      background: rgba(255, 255, 255, 0.12);
      padding: 30px;
      border-radius: 12px;
      box-shadow: 0px 8px 25px rgba(0, 0, 0, 0.3);
      width: 420px;
      text-align: center;
      color: #fff;
      backdrop-filter: blur(10px);
    }

    h2 {
      font-size: 24px;
      margin-bottom: 20px;
      font-weight: 600;
      color: #f1f1f1;
    }

    form {
      display: flex;
      flex-direction: column;
    }

    label {
      text-align: left;
      font-size: 14px;
      margin-top: 10px;
    }

    input {
      background: rgba(255, 255, 255, 0.2);
      border: none;
      padding: 12px;
      margin: 5px 0;
      border-radius: 6px;
      font-size: 16px;
      color: #fff;
      outline: none;
      transition: 0.3s;
    }

    input.invalid {
      border: 2px solid red;
    }

    .input-error {
      color: red;
      font-size: 0.85em;
      margin-bottom: 5px;
      text-align: left;
      display: none;
    }

    input:focus {
      background: rgba(255, 255, 255, 0.3);
      box-shadow: 0px 4px 10px rgba(255, 255, 255, 0.2);
    }

    .btn {
      display: inline-block;
      margin-top: 15px;
      padding: 12px 20px;
      font-size: 16px;
      font-weight: bold;
      border-radius: 8px;
      text-decoration: none;
      cursor: pointer;
      border: none;
      transition: all 0.3s ease-in-out;
      text-align: center;
    }

    .primary-btn {
      background: linear-gradient(135deg, #28a745, #218838);
      color: white;
      box-shadow: 0px 5px 15px rgba(40, 167, 69, 0.4);
      letter-spacing: 1px;
      border: none;
    }

    .primary-btn:hover {
      background: linear-gradient(135deg, #218838, #1e7e34);
      transform: scale(1.05);
      box-shadow: 0px 7px 20px rgba(40, 167, 69, 0.6);
    }

    .primary-btn:active {
      transform: scale(0.95);
      box-shadow: 0px 3px 10px rgba(0, 0, 0, 0.4);
    }
  </style>
</head>
<body>
  <div class="container">
    <h2>Edit Customer</h2>
    <form id="editCustomerForm" action="/milkman/<%= customer._id %>?_method=put" method="post" novalidate>
      
      <label for="first">First Name</label>
      <input type="text" name="customer[first]" id="first" value="<%= customer.first %>" required />
      <div class="input-error" id="firstError">Please enter first name.</div>

      <label for="last">Last Name</label>
      <input type="text" name="customer[last]" id="last" value="<%= customer.last %>" required />
      <div class="input-error" id="lastError">Please enter last name.</div>

      <label for="contact">Contact</label>
      <input type="text" name="customer[contact]" id="contact" value="<%= customer.contact %>" required />
      <div class="input-error" id="contactError">Enter a valid 10-digit contact number.</div>

      <label for="address">Address</label>
      <input type="text" name="customer[address]" id="address" value="<%= customer.address %>" required />
      <div class="input-error" id="addressError">Please enter address.</div>

      <button type="submit" class="btn primary-btn">Edit</button>
    </form>
    <br />
    <a href="/milkman/allcustomers"><button class="btn primary-btn">Back</button></a>
  </div>

  <script>
    const form = document.getElementById('editCustomerForm');

    form.addEventListener('submit', function (e) {
      let valid = true;

      const fields = {
        first: form.querySelector('#first'),
        last: form.querySelector('#last'),
        contact: form.querySelector('#contact'),
        address: form.querySelector('#address')
      };

      const showError = (field, errorId, condition) => {
        const error = document.getElementById(errorId);
        if (condition) {
          error.style.display = 'block';
          field.classList.add('invalid');
          valid = false;
        } else {
          error.style.display = 'none';
          field.classList.remove('invalid');
        }
      };

      showError(fields.first, 'firstError', !fields.first.value.trim());
      showError(fields.last, 'lastError', !fields.last.value.trim());
      showError(fields.contact, 'contactError', !/^\d{10}$/.test(fields.contact.value.trim()));
      showError(fields.address, 'addressError', !fields.address.value.trim());

      if (!valid) e.preventDefault();
    });
  </script>
</body>
</html>
