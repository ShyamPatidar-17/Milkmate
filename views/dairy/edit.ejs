<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Edit Customer</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet" />

  <style>
    body {
      font-family: 'Poppins', sans-serif;
      background-color: #f8f9fa; /* Light gray background */
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      margin: 0;
      padding: 20px;
      color: #333;
    }

    .container {
      background: #ffffff;
      padding: 40px 35px;
      border-radius: 16px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
      width: 100%;
      max-width: 440px;
    }

    h2 {
      font-size: 2rem;
      font-weight: 700;
      margin-bottom: 28px;
      text-align: center;
      color: #333;
    }

    form {
      display: flex;
      flex-direction: column;
    }

    label {
      font-weight: 600;
      font-size: 1rem;
      margin-top: 15px;
      margin-bottom: 6px;
      color: #555;
    }

    input {
      background: #f1f1f1;
      border: 1.5px solid #ccc;
      padding: 12px 14px;
      border-radius: 8px;
      font-size: 1rem;
      color: #333;
      outline: none;
      transition: border-color 0.3s ease, background-color 0.3s ease;
    }

    input:focus {
      border-color: #054585;
      background: #fff;
    }

    .btn {
      margin-top: 24px;
      padding: 14px 0;
      font-size: 1rem;
      font-weight: 600;
      border-radius: 10px;
      cursor: pointer;
      border: none;
      width: 100%;
      transition: background-color 0.3s ease, transform 0.2s ease;
    }

    .primary-btn {
      background-color: #054585;
      color: white;
    }

    .primary-btn:hover {
      background-color: #043668;
      transform: scale(1.02);
    }

    .primary-btn:active {
      transform: scale(0.97);
    }

    .back-link {
      display: block;
      margin-top: 16px;
      text-align: center;
      text-decoration: none;
    }

    .back-link .btn {
      background: #dee2e6;
      color: #333;
    }

    .back-link .btn:hover {
      background: #ced4da;
      transform: scale(1.02);
    }

    @media (max-width: 480px) {
      body {
        padding: 15px;
      }

      .container {
        padding: 30px 25px;
      }

      h2 {
        font-size: 1.6rem;
      }

      label,
      input,
      .btn {
        font-size: 0.95rem;
      }
    }
  </style>
</head>
<body>

  <div class="container">
    <h2>Edit Customer</h2>

    <form action="/customers/<%= customer._id %>?_method=PUT" method="POST">
      <label for="first">First Name</label>
      <input type="text" id="first" name="customer[first]" value="<%= customer.first %>" required />

      <label for="last">Last Name</label>
      <input type="text" id="last" name="customer[last]" value="<%= customer.last %>" required />

      <label for="contact">Contact</label>
      <input type="text" id="contact" name="customer[contact]" value="<%= customer.contact %>" required />

      <label for="address">Address</label>
      <input type="text" id="address" name="customer[address]" value="<%= customer.address %>" required />

      <button type="submit" class="btn primary-btn">Update</button>
    </form>
    <a href="/customers/allcustomers" class="back-link">
      <button class="btn">Back</button>
    </a>
  </div>

</body>
</html>
