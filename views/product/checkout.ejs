<%- include('../includes/navbar.ejs') %>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Checkout</title>
  <link rel="stylesheet" href="/css/product/checkout.css">
</head>
<body>
  <section class="checkout-container">
    <h1>Checkout</h1>

    <div class="checkout-summary">
      <h2>Order Summary</h2>
      <ul>
        <% cart.forEach(item => { %>
          <li><%= item.name %> x <%= item.quantity %> — ₹<%= item.price * item.quantity %></li>
        <% }); %>
      </ul>
      <p class="total">Total: ₹<%= totalAmount %></p>
      <div style="margin-bottom: 20px;">
  <a href="/product/all" class="add-more-btn">← Add More Products</a>
</div>

    </div>

    <div class="checkout-form">
      <h2>Billing Details</h2>
      <form action="/cart/pay" method="POST">
        <label for="fullname">Full Name</label>
        <input type="text" name="fullname" value="<%=user.name%>" required>
        <label for="contact">Contact Number</label>
        <input type="tel" name="contact" value="<%=user.mobile%>" required>
        <label for="address">Address</label>
        <textarea name="address" value="<%=user.address%>" required></textarea>

        <label for="payment">Payment Method</label>
        <select name="payment" required>
          <option value="cod">Cash on Delivery</option>
          <option value="card">Credit/Debit Card</option>
          <option value="upi">UPI</option>
        </select>
        <div id="card-details" style="display: none;">
            <label for="cardNumber">Card Number</label>
            <input type="text" name="cardNumber" placeholder="XXXX-XXXX-XXXX-XXXX" maxlength="19">
          
            <label for="cardExpiry">Expiry Date</label>
            <input type="text" name="cardExpiry" placeholder="MM/YY" maxlength="5">
          
            <label for="cardCVC">CVC</label>
            <input type="text" name="cardCVC" placeholder="123" maxlength="3">
          </div>
          
          <div id="upi-details" style="display: none;">
            <label for="upiId">UPI ID</label>
            <input type="text" name="upiId" placeholder="example@upi">
          </div>

        <button type="submit" class="pay-btn">Pay Now</button>
      </form>
    </div>
  </section>

  <%- include('../includes/footer.ejs') %>

  <script>
    const paymentSelect = document.querySelector('select[name="payment"]');
    const cardDetails = document.getElementById('card-details');
    const upiDetails = document.getElementById('upi-details');
  
    paymentSelect.addEventListener('change', function () {
      cardDetails.style.display = this.value === 'card' ? 'block' : 'none';
      upiDetails.style.display = this.value === 'upi' ? 'block' : 'none';
    });
  </script>
  
</body>
</html>
