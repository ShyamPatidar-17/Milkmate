<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Edit Product</title>
  <link rel="stylesheet" href="../css/product/edit.css">

  <style>
    body {
    font-family: Arial, sans-serif;
    background-color: #f2f2f2;
    margin: 0;
    padding: 0;
  }
  
  .edit-container {
    width: 50%;
    margin: 50px auto;
    background-color: #fff;
    padding: 30px 40px;
    border-radius: 15px;
    box-shadow: 0 0 10px rgba(0,0,0,0.1);
  }
  
  .edit-form h1 {
    text-align: center;
    margin-bottom: 25px;
    color: #333;
  }
  
  .edit-form label {
    display: block;
    margin-top: 15px;
    margin-bottom: 5px;
    font-weight: bold;
  }
  
  .edit-form input[type="text"],
  .edit-form input[type="number"],
  .edit-form textarea {
    width: 100%;
    padding: 10px;
    border: 1px solid #ccc;
    border-radius: 8px;
    box-sizing: border-box;
  }
  
  .edit-form textarea {
    resize: vertical;
  }
  
  .edit-form button {
    margin-top: 25px;
    width: 100%;
    padding: 12px;
    background-color: #007BFF;
    border: none;
    color: white;
    font-size: 16px;
    border-radius: 8px;
    cursor: pointer;
  }
  
  .edit-form button:hover {
    background-color: #0056b3;
  }
  
  </style>
</head>
<body>
  <div class="edit-container">
    <form action="/product/edit/<%= product._id %>?_method=PUT" method="POST" class="edit-form">
      <h1>Edit Product</h1>

      <label for="name">Product Name:</label>
      <input type="text" id="name" name="product[name]" value="<%= product.name %>" required>

      <label for="price">Price (₹):</label>
      <input type="number" id="price" name="product[price]" step="0.01" value="<%= product.price %>" required>

      <label for="desc">Description:</label>
      <textarea id="desc" name="product[desc]" rows="4" required><%= product.desc %></textarea>

      <label for="image">Image URL:</label>
      <input type="text" id="image" name="product[image]" value="<%= product.image %>" required>

      <button type="submit">Update Product</button>
    </form>
  </div>
</body>
</html>
