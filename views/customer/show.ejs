<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Customer Details</title>
    <link rel="stylesheet" href="../css/dairy/showCustomer.css">
</head>
<body>

    
    <div class="container">
        <header class="navbar">
            <div class="logo">
                <img src="https://static.vecteezy.com/system/resources/previews/048/342/900/non_2x/cartoon-cow-logo-png.png" alt="MilkMate Logo">
            </div>
            <h1 class="title">MILKMATE</h1>
            <nav class="nav-links">
                <a href="/contact">Contact</a>
                <a href="/customerrs">Home</a>
            </nav>
        </header>

            <!-- <a href="/dairy"><button>Home</button></a>
            <a href="/dairy/add"><button>Add Milk</button></a>    -->


        <h1>Customer Details</h1>
        <!-- Customer Info Form -->
            <div class="customer-details">
                    <table class="contact-table">
                        <thead>
                            <tr>
                                <th>Code</th>
                                <th>Dairy Code</th>
                                <th>First Name</th>
                                <th>Last Name</th>
                                <th>Contact</th>
                                <th>Address</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><%=customer.code%></td>
                                <td><%=customer.codeD%></td>
                                <td><%=customer.first%></td>
                                <td><%=customer.last%></td>
                                <td><%=customer.contact %></td>
                                <td><%=customer.address %></td>
                
                            </tr>
                        </tbody>
                    </table>
                    </div>
                    
    
  <!-- customer Milk info -->
 <h1>Milk Details</h1>

 <div class="customer-details">
     <table class="contact-table">
         <thead>
             <tr>
                 <th>Date</th>
                 <th>Shift</th>
                 <th>Liter</th>
                 <th>Rate (  &#8377 / ltr )</th>
                 <th>Amount</th>
                 <th>Total Amount</th>
             </tr>
         </thead>
         <tbody>
                 <% for(milk of milks) { %>  
                 <tr>  
                  <td>  <%=milk.date.toDateString()%></td>
                  <td>   <%=milk.shift %></td>
                  <td>   <%= milk.liter%></td>
                  <td><%=milk.rate%></td>
                  <td>    &#8377;  <%= milk.amount%></td>
                  <td> &#8377;  <%=total+=milk.amount%></td>
                  </tr>
             <% }; %>
         </tbody>
     </table>
     <h1>Total amount to be paid till Date = <b> &#8377 <%=total%></b></h1>
    
</div>
     <!------Footer-->


    <footer class="site-footer">
        <div class="footer-content">
            <div class="footer-section">
                <h3>MILKMATE</h3>
                <p>Your smart partner in dairy management. Trusted by farms and cooperatives for reliable operations and milk traceability.</p>
            </div>
    
            <div class="footer-section">
                <h4>Quick Links</h4>
                <ul>
                    <li><a href="/dairy">Home</a></li>
                    <li><a href="/about">About</a></li>
                    <li><a href="/contact">Contact</a></li>
                </ul>
            </div>
    
            <div class="footer-section">
                <h4>Contact Us</h4>
                <p>Email: info@milkmate.com</p>
                <p>Phone: +91 79739 18569</p>
                <p>Location: Indore, Madhya Pradesh, India</p>
            </div>
        </div>
    
        <div class="footer-bottom">
            <p>&copy; 2025 MILKMATE. All rights reserved.</p>
        </div>
    </footer>
</body>
</html>
